# TITAN Architect — server-side environment (copy to .env.local; NEVER commit keys)
#
# Persistence (ADR-023). Leave unset to run on the zero-setup in-memory
# adapter (data lasts until the server restarts). Set BOTH to activate the
# durable Supabase store — see README "Durable persistence in 5 minutes".
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Lead Flow v1 (ADR-030) — enquiry notifications. Without these, TITAN uses
# the dev console channel (notifications print to the server log).
# RESEND_API_KEY=re_...
# RESEND_FROM=TITAN Leads <leads@yourdomain.example>
# TITAN_FOUNDER_EMAIL=you@example.com
# App origin used in notification deep links (defaults to http://localhost:4100).
# TITAN_APP_ORIGIN=https://app.yourdomain.example

# Media Pipeline (ADR-033) — image generation via Replicate (Flux 1.1 Pro).
# Founder-triggered only; every asset lands in the review gate. Never in CI.
# REPLICATE_API_TOKEN=r8_...
